*.swp
*.swo

# Claude Code cache
.claude/

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.*

# Node
node_modules/

# Virtual environments
.venv/
venv/
env/

# Dev folders (NEVER PUBLISH - development artifacts only)
# Wildcard pattern catches all: docs_dev, scripts_dev, tests_dev, samples_dev,
# examples_dev, downloads_dev, libs_dev, builds_dev, etc.
*_dev/

# AMCOS runtime logs (generated by AmcosOutput utility)
.amcos-logs/

# Rust
target/
Cargo.lock

# SERENA MCP state (local project metadata, not published)
.serena/

# git-cliff scratch — ephemeral release notes between bump and push
.git-cliff-release-notes.md

# rechecker plugin scratch (per-session worktree state, not published)
.rechecker/

# LLM Externalizer scan output (default per-project response cache)
llm_externalizer_output/

# tldr CLI cache and session state (.tldrignore is a tracked config file — do NOT ignore)
.tldr/
.tldr_session_*
